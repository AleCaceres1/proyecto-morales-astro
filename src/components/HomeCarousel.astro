---
const { slides = [] } = Astro.props;
---

<section id="home" class="hero-carousel">
  {slides.length > 0 ? (
    <>
      <div class="hero-track">
        {slides.map((slide, index) => (
          <article class={`hero-slide ${index === 0 ? 'active' : ''}`}>
            <picture>
              {slide.mobileImage && (
                <source media="(max-width: 768px)" srcset={slide.mobileImage} />
              )}

              <img src={slide.image} alt={slide.title} class="hero-image" />
            </picture>

            <div class="hero-overlay"></div>

            <div class="hero-content">
              <h1>{slide.title}</h1>
              <p>{slide.subtitle}</p>

              <a href={slide.buttonLink} class="hero-button">
                {slide.buttonText}
              </a>
            </div>
          </article>
        ))}
      </div>

      <button class="hero-arrow hero-arrow-left" type="button" aria-label="Previous slide">
        &#10094;
      </button>

      <button class="hero-arrow hero-arrow-right" type="button" aria-label="Next slide">
        &#10095;
      </button>

      <div class="hero-dots">
        {slides.map((_, index) => (
          <button
            type="button"
            class={`hero-dot ${index === 0 ? 'active' : ''}`}
            aria-label={`Go to slide ${index + 1}`}
          ></button>
        ))}
      </div>
    </>
  ) : (
    <div class="hero-empty">
      <h1>Morales Auto Brokers</h1>
      <p>Hero carousel content is not available yet.</p>
    </div>
  )}
</section>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.hero-dot');
  const previousButton = document.querySelector('.hero-arrow-left');
  const nextButton = document.querySelector('.hero-arrow-right');

  let currentSlide = 0;
  let intervalId;

  function showSlide(index: number) {
    if (!slides.length) return;

    slides[currentSlide]?.classList.remove('active');
    dots[currentSlide]?.classList.remove('active');

    currentSlide = index;

    slides[currentSlide]?.classList.add('active');
    dots[currentSlide]?.classList.add('active');
  }

  function nextSlide() {
    const next = (currentSlide + 1) % slides.length;
    showSlide(next);
  }

  function previousSlide() {
    const previous = (currentSlide - 1 + slides.length) % slides.length;
    showSlide(previous);
  }

  nextButton?.addEventListener('click', nextSlide);
  previousButton?.addEventListener('click', previousSlide);

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => showSlide(index));
  });

  if (slides.length > 1) {
    intervalId = window.setInterval(nextSlide, 5000);
  }
</script>

<style>

.hero-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);

    width: 56px;
    height: 56px;

    border-radius: 50%;
    border: 1px solid rgba(255,255,255,.25);

    background: rgba(0,0,0,.25);
    backdrop-filter: blur(8px);

    color: white;
    font-size: 24px;

    display: flex;
    align-items: center;
    justify-content: center;

    cursor: pointer;

    transition: .25s ease;

    z-index: 20;
}

.hero-arrow:hover{

    background: var(--color-accent);

    border-color: var(--color-accent);

    transform: translateY(-50%) scale(1.08);

}

.hero-arrow-left{

    left:32px;

}

.hero-arrow-right{

    right:32px;

}
  .hero-carousel {
  position: relative;
  width: 100vw;
  margin-left: calc(50% - 50vw);
  height: calc(100vh - var(--header-height));
  min-height: 560px;
  overflow: hidden;
  background: var(--color-bg);
}

  .hero-track,
  .hero-slide {
    height: 100%;
  }

  .hero-overlay {
  position: absolute;
  inset: 0;

  background:
    radial-gradient(
      circle at center,
      rgba(0,0,0,0) 35%,
      rgba(0,0,0,.25) 60%,
      rgba(0,0,0,.65) 100%
    ),

    linear-gradient(
      90deg,
      rgba(0,0,0,.80) 0%,
      rgba(0,0,0,.45) 35%,
      rgba(0,0,0,.15) 70%,
      rgba(0,0,0,.65) 100%
    );
}
.hero-vignette {
  position: absolute;
  inset: 0;
  pointer-events: none;

  background:
    linear-gradient(to right,
      rgba(17,17,17,.95) 0%,
      rgba(17,17,17,.55) 15%,
      rgba(17,17,17,0) 30%),

    linear-gradient(to left,
      rgba(17,17,17,.95) 0%,
      rgba(17,17,17,.55) 15%,
      rgba(17,17,17,0) 30%);
}

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s ease, visibility 0.8s ease;
  }

  .hero-slide.active {
    opacity: 1;
    visibility: visible;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.82),
      rgba(0, 0, 0, 0.45),
      rgba(0, 0, 0, 0.15)
    );
  }

  .hero-content {
    position: absolute;
    top: 50%;
    left: max(32px, calc((100vw - var(--container-width)) / 2));
    transform: translateY(-50%);
    max-width: 620px;
    color: var(--color-text);
  }

  .hero-content h1 {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    line-height: 1;
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .hero-content p {
    font-size: clamp(1rem, 2vw, 1.35rem);
    color: var(--color-text-muted);
    margin-bottom: 32px;
    max-width: 520px;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    color: white;
    padding: 14px 28px;
    border-radius: 999px;
    font-weight: 700;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .hero-button:hover {
    background: var(--color-accent-dark);
    transform: translateY(-2px);
  }

  .hero-dots {
    position: absolute;
    left: 50%;
    bottom: 32px;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 5;
  }

  .hero-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1px solid white;
    background: transparent;
  }

  .hero-dot.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .hero-carousel {
      height: calc(100vh - var(--header-height));
      min-height: 520px;
    }

    .hero-overlay {
      background: rgba(0, 0, 0, 0.65);
    }

    .hero-content {
      left: 24px;
      right: 24px;
      max-width: none;
      text-align: center;
    }

    .hero-content h1 {
      font-size: 2.5rem;
    }

    .hero-content p {
      margin-inline: auto;
    }
    .hero-arrow {
    width: 25px;
    height: 25px;

    font-size: 18px;
    }

    .hero-arrow-left {
        left: 12px;
    }

    .hero-arrow-right {
        right: 12px;
    }
  }
</style>