---
import '../../styles/global.css';
import Header from '../../components/Header.astro';

const lang = 'en';
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Coming Soon | Morales Auto Brokers</title>
  </head>

  <body>
    <Header lang={lang} />

    <main class="coming-soon-page">
      <section class="coming-soon">
        <div class="container coming-soon-content">
          <p class="eyebrow">Future improvement</p>
          <h1>We are working on it</h1>
          <p>
            This section is currently under development. Soon you will find more
            information here.
          </p>

          <a href="/en" class="coming-soon-button">Back to Home</a>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  .coming-soon {
    min-height: calc(100vh - var(--header-height));
    display: grid;
    place-items: center;
    text-align: center;
    background:
      radial-gradient(circle at center, rgba(214, 31, 38, 0.18), transparent 35%),
      var(--color-bg);
  }

  .coming-soon-content {
    max-width: 720px;
  }

  .eyebrow {
    color: var(--color-accent);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin-bottom: 16px;
  }

  .coming-soon h1 {
    font-size: clamp(2.8rem, 7vw, 6rem);
    line-height: 1;
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .coming-soon p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-bottom: 32px;
  }

  .coming-soon-button {
    display: inline-flex;
    background: var(--color-accent);
    color: white;
    padding: 14px 28px;
    border-radius: 999px;
    font-weight: 800;
    transition: 0.25s ease;
  }

  .coming-soon-button:hover {
    background: var(--color-accent-dark);
    transform: translateY(-2px);
  }
</style>